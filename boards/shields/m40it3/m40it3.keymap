#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/input_transform.h>
#include <dt-bindings/zmk/pointing.h>

/ {
    /* 通常移動用：あなたの環境で正しい「XY入れ替え＋X反転」を定義 */
    zip_xy: zip_xy {
        compatible = "zmk,input-processor-transform";
        #input-processor-cells = <1>;
        type = <0x02>;
        x-codes = <0x00>;
        y-codes = <0x01>;
    };

    /* スクロール用：通常移動の「XY入れ替え」が適用される前の生データを使って、
       物理的な移動方向を直接ホイールに紐付けます。
       左右(X) -> 垂直スクロール(WHEEL)
       上下(Y) -> 水平スクロール(HWHEEL) にあえて設定します。
    */
    zip_scroll: zip_scroll {
        compatible = "zmk,input-processor-transform";
        #input-processor-cells = <1>;
        type = <0x02>;
        x-codes = <0x00 0x08>; /* 生データXを垂直スクロールへ */
        y-codes = <0x01 0x06>; /* 生データYを水平スクロールへ */
    };

    trackball_listener: trackball_listener {
        compatible = "zmk,input-listener";
        device = <&trackball>;
        
        /* デフォルト：通常移動 */
        /* ここで明示的に軸を入れ替えています */
        input-processors = <&zip_xy (INPUT_TRANSFORM_XY_SWAP | INPUT_TRANSFORM_X_INVERT)>;

        /* ▽ 修正ポイント：強制切り替え ▽ */
        /* layer 1 がONの時、通常移動の「SWAP」を無視してスクロール専用軸を適用 */
        scrolling {
            layers = <1>;
            input-processors = <&zip_scroll 0>;
        };
    };
};

/* 外部のキーマップ（レイヤー定義）を「最後」に読み込むことで、
   上記で定義したリスナーがレイヤー情報を上書きされないようにします */
#include "../../../config/keymap.keymap"
